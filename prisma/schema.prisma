generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MEMBER
  ADMIN
  SUPERADMIN
}

enum CharacterApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id              String    @id @default(uuid())
  name            String?
  email           String?   @unique
  emailVerified   DateTime? @map("email_verified")
  image           String?

  discordId       String    @unique @map("discord_id")
  discordUsername String    @unique @map("discord_username")
  displayName     String?   @map("display_name")
  nickname        String?   @unique @map("nickname")

  role            UserRole  @default(MEMBER)
  isActive        Boolean   @default(true) @map("is_active")
  isOnboarded     Boolean   @default(false) @map("is_onboarded")

  joinedAt        DateTime  @default(now()) @map("joined_at")
  lastLoginAt     DateTime? @map("last_login_at")

  discordMembershipCheckedAt  DateTime? @map("discord_membership_checked_at")
  discordMembershipLeftAt     DateTime? @map("discord_membership_left_at")
  discordMembershipRejoinedAt DateTime? @map("discord_membership_rejoined_at")

  accounts        Account[]
  sessions        Session[]
  characters      Character[]

  characterApplications CharacterApplication[] @relation("UserCharacterApplications")
  reviewedCharacterApplications CharacterApplication[] @relation("ReviewedCharacterApplications")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Character {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")

  name           String
  phoneNumber    String?  @map("phone_number")
  rank           String?
  division       String?
  specialization String?  @map("specialization")
  yearsOfService Int?     @map("years_of_service")

  isPrimary      Boolean  @default(false) @map("is_primary")
  isActive       Boolean  @default(true) @map("is_active")

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("characters")
}

model CharacterApplication {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")

  oocNickname     String   @map("ooc_nickname")
  characterName   String   @map("character_name")
  phoneNumber     String   @map("phone_number")
  rank            String
  division        String
  specialization  String?
  yearsOfService  Int      @map("years_of_service")

  status          CharacterApplicationStatus @default(PENDING)

  reviewedById    String?   @map("reviewed_by_id")
  reviewedAt      DateTime? @map("reviewed_at")
  rejectionReason String?   @map("rejection_reason")

  user            User  @relation("UserCharacterApplications", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy      User? @relation("ReviewedCharacterApplications", fields: [reviewedById], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([reviewedById])
  @@map("character_applications")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}